# =============================================================================
# Public site configuration.
#
# Every key here is exposed to the browser, so it MUST keep the NEXT_PUBLIC_
# prefix. Copy this file to .env.local and fill in your values:
#     cp .env.example .env.local
# On Vercel/Netlify, set the same keys in the project's Environment Variables
# dashboard instead of committing them.
# =============================================================================

# --- Contact ---
NEXT_PUBLIC_EMAIL=you@example.com

# Optional. Leave blank to hide the phone entry in the contact section.
NEXT_PUBLIC_PHONE=

NEXT_PUBLIC_LINKEDIN=https://www.linkedin.com/in/your-handle
NEXT_PUBLIC_GITHUB=https://github.com/your-handle

# --- Resume (Google Drive link) ---
# Paste your Drive share link. It opens in a new tab.
# A share link looks like:
#     https://drive.google.com/file/d/FILE_ID/view?usp=sharing
# For a direct download instead of the Drive preview, use this form:
#     https://drive.google.com/uc?export=download&id=FILE_ID
NEXT_PUBLIC_RESUME_URL=https://drive.google.com/file/d/FILE_ID/view

# --- Location (shown in hero + contact) ---
NEXT_PUBLIC_LOCATION=Ahmedabad, Gujarat, India

# --- Deployed URL (canonical, Open Graph, JSON-LD). No trailing slash. ---
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# --- Contact form (Web3Forms) ---
# Free access key from https://web3forms.com (enter your email, no password).
# It is safe to expose publicly; it only accepts submissions.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
